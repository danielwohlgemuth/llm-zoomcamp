{
    "name": "homework-02-vector-search",
    "image": "mcr.microsoft.com/devcontainers/base:bookworm",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}/homework/02-vector-search",
    "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh",
    "postCreateCommand": "export PATH=\"$HOME/.local/bin:$PATH\" && cd ${containerWorkspaceFolder} && uv sync",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    }
}